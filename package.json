{
  "name": "dotfiles",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "help": "bun run config/help.ts",
    "input-test": "bun run config/terminal-input-test.ts",
    "commit": "bun run config/git/ai-commit.ts",
    "claude:setup": "bun run config/claude/setup-settings.ts",
    "lint": "bun run lint:shell && bun run lint:zsh",
    "lint:shell": "shellcheck install.sh scripts/*.sh",
    "lint:zsh": "zsh -c 'for f in .zshrc functions/*.sh; do zsh -n $f || exit 1; done'"
  },
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
